# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# ASRbench runtime
~/.asrbench/
*.db
*.db-wal
*.db-shm

# Local environment config written by setup_env.py (machine-specific)
.asrbench-env
pyright_output.json

# Benchmark/autotune runtime artifacts
scripts/benchmarks/run.log
scripts/benchmarks/results.tsv

# Claude Code session state — never commit
.claude/

# Audio / model artifacts
*.npy
*.pt
*.bin
*.gguf
*.onnx

# Testing
.pytest_cache/
.coverage
htmlcov/

# Type checking
.mypy_cache/

# Ruff
.ruff_cache/

# Node / Svelte UI build
node_modules/
ui/dist/
ui/.svelte-kit/
# asrbench/static/** is intentionally NOT ignored — CI builds the Vite
# bundle and commits it so `pip install asrbench` ships a working UI.
# The checked-in artefact is regenerated on every release workflow.

